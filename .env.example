# Copy this file to `.env` (Docker) or `.env.local` (npm dev) and fill in
# the values you have. Both files are git-ignored.

# Optional but strongly recommended.
# Lifts GitHub PoC search rate limits from 10 req/min (unauthenticated)
# to 30 req/min. Generate at https://github.com/settings/tokens
# (classic token, no scopes needed — or just `public_repo`).
GITHUB_TOKEN=

# Optional. Lifts NVD API rate limits substantially.
# Request at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Optional. Path to the SQLite file used for the /assets inventory (defaults to
# data/pocwatch.db under the process working directory). Relative paths are
# resolved from the project / container cwd.
# SQLITE_PATH=data/pocwatch.db
